function Get-NumericRiskScore {
    <#
    .SYNOPSIS
    Converts severity to numeric risk score with optional context-based weighting
    #>
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [ValidateSet('Critical','High','Medium','Low','Info')]
        [string],

        [string] = '',
        [string]@{Area=GPOs; Finding=64 GPOs have no links (candidates to retire or migrate to Intune); Severity=Low; Evidence=ad-gpo-links; Impact=Unlinked GPOs create configuration drift and potential security gaps if accidentally re-linked; RemediationSteps=1. Review unlinked GPOs in evidence CSV|2. Document purpose and historical context|3. Backup GPO settings using Backup-GPO cmdlet|4. Delete or archive unlinked GPOs after stakeholder approval|5. Plan migration of remaining security GPOs to Intune configuration profiles|6. Develop GPO decommissioning roadmap; Reference=https://learn.microsoft.com/en-us/mem/intune/configuration/device-profiles; EstimatedEffort=3-6 hours; Category=Modernization; Owner=; DueDate=; Status=Open; MITRETechniques=T1484; MITRETactics=Privilege Escalation, Defense Evasion; SecurityCategory=Attack Surface Reduction; HealthCategory=Modernization; RiskScore=3; BusinessImpact=Low} = ''
    )

     = switch () {
        'Critical' { 95 }
        'High'     { 80 }
        'Medium'   { 55 }
        'Low'      { 30 }
        default    { 10 }
    }

    # Add context-based weight adjustments
     = 0
    if ( -match 'Privileged|Global Admin|Domain Admin') {  += 10 }
    if ( -match 'OAuth|Service Principal')              {  += 5  }
    if (@{Area=GPOs; Finding=64 GPOs have no links (candidates to retire or migrate to Intune); Severity=Low; Evidence=ad-gpo-links; Impact=Unlinked GPOs create configuration drift and potential security gaps if accidentally re-linked; RemediationSteps=1. Review unlinked GPOs in evidence CSV|2. Document purpose and historical context|3. Backup GPO settings using Backup-GPO cmdlet|4. Delete or archive unlinked GPOs after stakeholder approval|5. Plan migration of remaining security GPOs to Intune configuration profiles|6. Develop GPO decommissioning roadmap; Reference=https://learn.microsoft.com/en-us/mem/intune/configuration/device-profiles; EstimatedEffort=3-6 hours; Category=Modernization; Owner=; DueDate=; Status=Open; MITRETechniques=T1484; MITRETactics=Privilege Escalation, Defense Evasion; SecurityCategory=Attack Surface Reduction; HealthCategory=Modernization; RiskScore=3; BusinessImpact=Low} -match 'No Conditional Access|legacy auth') {  += 5  }

    # Clamp to 0-100 range
    [Math]::Min(100, [Math]::Max(0,  + ))
}

